# Azure Language NER fallback (used when regex finds nothing)
NER_SUBSCRIPTION_KEY=

# Optional LLM escalation. Leave OPENROUTER_API_KEY blank to run deterministic-only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Scan behaviour
RETENTION_YEARS=3
SCAN_TARGET_DIR=./sample-data
PORT=8080
ALLOWED_ORIGINS=*

# URL of the FastAPI service used by the Streamlit UI to call REST endpoints.
# In production set this to your deployed API URL, e.g. https://gdpr-scanner-api.onrender.com
API_BASE_URL=http://localhost:8080
