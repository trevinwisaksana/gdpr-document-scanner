# Azure Language NER fallback (used when regex finds nothing)
NER_SUBSCRIPTION_KEY=

# Optional LLM escalation. Leave OPENROUTER_API_KEY blank to run deterministic-only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Scan behaviour
RETENTION_YEARS=3
SCAN_TARGET_DIR=./sample-data

# Scalable architecture (dispatcher + scanner worker services)
GCP_PROJECT_ID=
GCS_BUCKET_NAME=               # bucket containing documents to scan
GCS_FILE_PREFIX=               # optional path prefix, e.g. "uploads/"
PUBSUB_TOPIC_ID=gdpr-scan-jobs
