# ── Backend (Google Cloud Run) ────────────────────────────────────────────────
# Base URL of the deployed FastAPI backend. When set, the app will try to read
# live data (KPIs, flagged files, scan trigger) from here and fall back to the
# bundled demo dataset for any endpoint that isn't live yet.
# Leave blank to run fully on demo data (recommended for a self-contained demo).
NEXT_PUBLIC_API_BASE_URL=https://dashboard-http-95861934207.us-central1.run.app

# Force demo mode even if an API base URL is set (true/false).
NEXT_PUBLIC_DEMO_MODE=false

# ── Local Ollama (for the "explain why flagged" summary) ───────────────────────
# The summary is generated by an Ollama instance running on the *viewer's* machine,
# so this is called directly from the browser. Ollama must allow the origin via
# OLLAMA_ORIGINS. Example: OLLAMA_ORIGINS=* ollama serve
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434
NEXT_PUBLIC_OLLAMA_MODEL=llama3.2
